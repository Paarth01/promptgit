# Copy to .env and adjust. docker-compose.yml reads these automatically;
# for local (non-Docker) runs, export them or use `python-dotenv` yourself.

# ── Database ──────────────────────────────────────────────────────────────
# Used by: api, metrics_worker, scripts/create_api_key.py
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/prompt_ab

# ── Cache / queue ─────────────────────────────────────────────────────────
# Used by: api (serve-routing cache, event queue push), metrics_worker (queue consumer)
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────
# "true" bypasses API-key auth entirely (dev/demo convenience). Leave unset
# or "false" for anything resembling production — every request then needs
# an X-API-Key header (see scripts/create_api_key.py to bootstrap the first one).
AUTH_DISABLED=false

# ── LLM-judge collector ───────────────────────────────────────────────────
# Required only for POST /events/judge with collector="llm_judge".
# task_accuracy (the other built-in collector) needs no external key.
ANTHROPIC_API_KEY=

# ── Auto-promotion ────────────────────────────────────────────────────────
# "true" (default): the system itself activates a winning version once it
# clears sample size + significance + hold period + no guardrail. "false":
# winners are only flagged; a human must click Promote in the dashboard.
AUTO_PROMOTE_ENABLED=true

# Hours an experiment must run past its start time before it's eligible for
# auto-promotion, even if significance is reached earlier — protects against
# day-of-week/time-of-day confounds in early data. Real deployments should
# use 24 (or leave unset, since 24 is the code default). docker-compose.yml
# overrides this to a short demo value so `docker-compose up` alone produces
# a completed experiment within a couple of minutes instead of a real day.
HOLD_PERIOD_HOURS=24

# ── Dashboard ─────────────────────────────────────────────────────────────
# Used by: dashboard/app.py to reach the API and authenticate.
API_BASE_URL=http://localhost:8000
API_KEY=

# ── Test suite (tests/test_integration.py only) ──────────────────────────
# Point at a *test* database, not your real one — the integration suite
# creates and mutates real rows. Defaults to prompt_ab_test on localhost if
# unset; override here or via shell env when running pytest directly.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/prompt_ab_test
# REDIS_URL=redis://localhost:6379/0
